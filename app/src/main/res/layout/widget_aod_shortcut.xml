<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/rounded_widget_background"
    android:padding="8dp">

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_centerInParent="true"
        android:contentDescription="@string/widget_label"
        android:src="@drawable/widget_aod_settings" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_icon"
        android:layout_centerHorizontal="true"
        android:text="@string/widget_label"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:maxLines="2"
        android:gravity="center" />

</RelativeLayout>